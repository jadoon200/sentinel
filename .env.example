# Copy to .env and fill in. Everything works with defaults + no keys (lower rate limits).
SENTINEL_DATABASE_URL=postgresql+psycopg://sentinel:sentinel@localhost:5432/sentinel

# Optional, free: https://nvd.nist.gov/developers/request-an-api-key
SENTINEL_NVD_API_KEY=

# Optional, free tier: https://otx.alienvault.com (used from week 2)
SENTINEL_OTX_API_KEY=
